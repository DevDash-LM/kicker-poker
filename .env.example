# ---------------------------------------------------------------------------
# Kicker environment
# Copy to `.env` (or `.env.local`) and fill in. Accounts are OPTIONAL: leave the
# Supabase vars blank and the app runs exactly as before — guest play only.
# ---------------------------------------------------------------------------

# --- Client (build-time, embedded by Vite). The anon key is designed to be
#     public; Row Level Security protects the data. Do NOT put the service_role
#     key here. ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: point the multiplayer client at a specific WebSocket server.
# Defaults to the same host as the page (…/ws).
# VITE_WS_URL=

# ---------------------------------------------------------------------------
# --- Supabase Edge Function secrets (server-side ONLY — never shipped to the
#     browser). Set with: supabase secrets set KEY=value
#     These power the branded confirmation-code email (send-email hook). ---
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxx           # from https://resend.com (else codes are logged)
# KICKER_EMAIL_FROM=Kicker <login@yourdomain.com>
# KICKER_PUBLIC_URL=https://kicker.example.com   # used for the logo in emails
# SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxx        # from Auth → Hooks → Send Email
